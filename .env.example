# ============================================================
# Flood Risk Prediction System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your regional settings.
# Note: This build is optimized for OFFLINE HISTORICAL SIMULATION (2022 Monsoon).
# API credentials for Copernicus/GloFAS are no longer required.

# ── Data & Simulation Mode ──
# Mode set to 'offline' (internal data layer)
# Current Dataset: data/raw/glofas/prediction/glofas_v4_india_river_discharge_jun_aug_2022.grib

# ── Geospatial ──
# Target CRS (auto-detected from AOI longitude if empty)
FLOOD_GEO_target_crs=EPSG:32644

# DEM source: alos_palsar (12.5m) | cop_dem_30 | srtm_30
FLOOD_GEO_dem_source=alos_palsar

# ── LSTM Model ──
# Device: cuda (RTX 4050) | cpu
FLOOD_LSTM_device=cuda

# Mixed precision training (FP16) — 2× speedup on RTX 4050
FLOOD_LSTM_mixed_precision=true

# ── XGBoost ──
# GPU training: gpu_hist (RTX 4050) | hist (CPU)
FLOOD_XGB_tree_method=gpu_hist
FLOOD_XGB_device=cuda:0

# ── API ──
FLOOD_API_host=0.0.0.0
FLOOD_API_port=8000
# Optional API key for backend authentication
FLOOD_API_api_key=

# ── Dashboard ──
# URL for the FastAPI backend service
FLOOD_DASH_api_base_url=http://localhost:8000
FLOOD_DASH_refresh_interval_sec=300
