# ============================================================
# Flood Risk Prediction System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
# All variables are optional — the system has sensible defaults.

# ── Data Architecture: Hybrid Global-India ──
# India-WRIS API key (request from https://indiawris.gov.in)
FLOOD_DATA_wris_api_key=

# NASA Earthdata token (for GPM and SMAP)
# Register at https://urs.earthdata.nasa.gov/
FLOOD_DATA_nasa_earthdata_token=

# Copernicus Data Space (for Sentinel products)
# Register at https://dataspace.copernicus.eu/
FLOOD_DATA_copernicus_client_id=
FLOOD_DATA_copernicus_client_secret=

# Google Earth Engine (Community Edition)
FLOOD_DATA_gee_project_id=
FLOOD_DATA_gee_service_account_json_path=

# Global Fallback (GRDC/GloFAS)
FLOOD_DATA_enable_global_fallback=true

# ── Geospatial ──
# Target CRS (auto-detected from AOI longitude if empty)
FLOOD_GEO_target_crs=

# DEM source: alos_palsar (12.5m) | cop_dem_30 | srtm_10
FLOOD_GEO_dem_source=srtm_10

# ── LSTM Model ──
# Device: cuda (RTX 4050) | cpu
FLOOD_LSTM_device=cuda

# Mixed precision training (FP16) — 2× speedup on RTX 4050
FLOOD_LSTM_mixed_precision=true

# ── XGBoost ──
# GPU training: gpu_hist (RTX 4050) | hist (CPU)
FLOOD_XGB_tree_method=gpu_hist
FLOOD_XGB_device=cuda:0

# ── API ──
FLOOD_API_host=0.0.0.0
FLOOD_API_port=8000
# Optional API key for authentication
FLOOD_API_api_key=

# ── Dashboard ──
FLOOD_DASH_api_base_url=http://localhost:8000
FLOOD_DASH_refresh_interval_sec=300
